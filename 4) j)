import random


palabras = ["python", "computadora", "programacion", "teclado", "pantalla"]


palabra = random.choice(palabras)

oculta = ["_"] * len(palabra)
oculta[0] = palabra[0]

print("Adiviná la palabra:")
print(" ".join(oculta))

# Mientras falten letras
while "_" in oculta:
    letra = input("Ingresá una letra: ").lower()

    if len(letra) != 1:
        print("Ingresá solo una letra")
        continue

    if letra in palabra:
        # Revelar letras correctas
        for i in range(len(palabra)):
            if palabra[i] == letra:
                oculta[i] = letra
        print("¡Correcto!")
    else:
        print("Letra incorrecta")

    print(" ".join(oculta))

print("¡Ganaste! La palabra era:", palabra)
