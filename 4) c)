# Leer la cantidad de elementos
n = int(input("¿Cuántos números vas a ingresar?: "))

numeros = []

# Pedir los números
for i in range(n):
    num = int(input(f"Ingresá el número {i+1}: "))
    numeros.append(num)

# Calcular el mínimo
minimo = min(numeros)

# Mostrar resultado
print("El elemento mínimo del arreglo es:", minimo)
