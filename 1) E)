#include <iostream>
using namespace std;

int main() {
    int numero;

    cout << "Ingrese un numero del 1 al 7: ";
    cin >> numero;

    if (numero == 1) {
        cout << "Lunes" << endl;
    }
    else if (numero == 2) {
        cout << "Martes" << endl;
    }
    else if (numero == 3) {
        cout << "Miercoles" << endl;
    }
    else if (numero == 4) {
        cout << "Jueves" << endl;
    }
    else if (numero == 5) {
        cout << "Viernes" << endl;
    }
    else if (numero == 6) {
        cout << "Sabado" << endl;
    }
    else if (numero == 7) {
        cout << "Domingo" << endl;
    }
    else {
        cout << "Error: numero fuera de rango" << endl;
    }

    return 0;
}
