#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cout << "¿Cuántos números vas a ingresar?: ";
    cin >> n;

    vector<int> numeros(n);

    for (int i = 0; i < n; i++) {
        cout << "Ingresá el número " << i + 1 << ": ";
        cin >> numeros[i];
    }


    int maximo = numeros[0];
    for (int i = 1; i < n; i++) {
        if (numeros[i] > maximo) {
            maximo = numeros[i];
        }
    }


    cout << "El elemento máximo del arreglo es: " << maximo << endl;

    return 0;
}
